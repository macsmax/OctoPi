# Get your API key from: https://octopus.energy/dashboard/new/accounts/personal-details/api-access
OCTOPUS_API_KEY=sk_live_XXXXXXXXXXXXXXXXXXXXXXXX

# Your account number (format: A-XXXXXXXX)
OCTOPUS_ACCOUNT_NUMBER=A-XXXXXXXX

# Meter details are auto-discovered from your account via the API.
# No need to configure them manually.

# Enable EV charging tab (set to true if you have an electric car)
EV_CHARGING=true

# Home charger draw rate in kW (used to identify EV charging in off-peak data)
# 7kW is typical for a home wallbox, 3.6kW for a granny charger
EV_CHARGER_KW=7
